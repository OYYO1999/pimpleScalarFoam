FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      decomposeParDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

numberOfSubdomains  30;

method          scotch;


constraints
{
    preservePatches
    {
        type            preservePatches;
        patches         (INLET OUTLET WALL_L WALL_R);
    }
}

